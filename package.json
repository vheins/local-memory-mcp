{
	"name": "mcp-memory-local",
	"version": "0.1.0",
	"description": "MCP Local Memory Service for coding copilot agents",
	"type": "module",
	"main": "dist/server.js",
	"bin": {
		"mcp-memory-local": "./dist/server.js",
		"mcp-memory-dashboard": "./dist/dashboard/server.js"
	},
	"scripts": {
		"build": "tsc && cp -r src/dashboard/public dist/dashboard/",
		"dev": "tsc --watch",
		"start": "node dist/server.js",
		"dashboard": "node dist/dashboard/server.js",
		"both": "npm run start & npm run dashboard",
		"test": "vitest --run",
		"test:watch": "vitest"
	},
	"keywords": [
		"mcp",
		"memory",
		"ai",
		"coding-copilot"
	],
	"author": "",
	"license": "MIT",
	"dependencies": {
		"better-sqlite3": "^12.6.2",
		"express": "^5.2.1",
		"qs": "^6.15.0",
		"zod": "^4.3.5"
	},
	"devDependencies": {
		"@fast-check/vitest": "^0.3.0",
		"@types/better-sqlite3": "^7.6.13",
		"@types/express": "^5.0.6",
		"@types/node": "^22.19.7",
		"fast-check": "^4.6.0",
		"typescript": "^5.7.3",
		"vitest": "^4.1.1"
	}
}
